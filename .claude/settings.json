{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cmake --build *)",
      "Bash(cmake --preset *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Read(.claude/Data/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)"
    ]
  },
  "attribution": {
    "commits": false,
    "pullRequests": false
  }
}